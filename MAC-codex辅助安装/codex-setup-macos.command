#!/bin/zsh
# Codex Setup for macOS v1.0
# ============================
# One-click setup: relay + Chinese LLMs for Codex (macOS edition)
#
# Usage:
#   chmod +x codex-setup-macos.sh
#   ./codex-setup-macos.sh
#
# Requires: Python 3, Codex (CLI or Desktop)

# 如果用户用 bash 执行，自动切到 zsh
if [[ -z "$ZSH_VERSION" ]]; then
  command -v zsh >/dev/null 2>&1 && exec zsh "$0" "$@"
fi

# 脚本自身路径（zsh 函数内 $0 是函数名，不是脚本！）
SCRIPT_FILE="$0"

CODEX_DIR="$HOME/.codex"
CONFIG="$CODEX_DIR/config.toml"
AUTH="$CODEX_DIR/auth.json"
VARS="$CODEX_DIR/_vars.sh"
RS="$CODEX_DIR/restart-relay.sh"

# ── 颜色定义 ──
GREEN=$'\033[0;32m'
RED=$'\033[0;31m'
YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# ── Model database ──
CODES=(D1 D2 Q1 Q2 Q3 Q4 Q5 Q6 Q7 K1 K2 G1 G2 G3 G4 G5 G6 G7 G8 M1 M2 M3 M4 M5 M6 M7 M8)
NAMES=(deepseek-v4-pro deepseek-v4-flash qwen-max qwen-plus qwen-turbo qwen-coder-plus qwen-vl-max qwen3.6-plus qwen3.5-plus kimi-k2.6 kimi-k2.5 glm-4.7-flash glm-4-flash glm-4-plus glm-4v-flash glm-4-long glm-5.1 glm-5v-turbo glm-5
PROVIDERS=(DeepSeek DeepSeek Qwen Qwen Qwen Qwen Qwen Qwen Qwen Kimi Kimi GLM GLM GLM GLM GLM GLM GLM GLM
URLS=("https://api.deepseek.com/v1" "https://api.deepseek.com/v1" "https://dashscope.aliyuncs.com/compatible-mode/v1" "https://dashscope.aliyuncs.com/compatible-mode/v1" "https://dashscope.aliyuncs.com/compatible-mode/v1" "https://dashscope.aliyuncs.com/compatible-mode/v1" "https://dashscope.aliyuncs.com/compatible-mode/v1" "https://dashscope.aliyuncs.com/compatible-mode/v1" "https://dashscope.aliyuncs.com/compatible-mode/v1" "https://api.moonshot.cn/v1" "https://api.moonshot.cn/v1" "https://open.bigmodel.cn/api/paas/v4" "https://open.bigmodel.cn/api/paas/v4" "https://open.bigmodel.cn/api/paas/v4" "https://open.bigmodel.cn/api/paas/v4" "https://open.bigmodel.cn/api/paas/v4" "https://open.bigmodel.cn/api/paas/v4" "https://open.bigmodel.cn/api/paas/v4" "https://open.bigmodel.cn/api/paas/v4"
KEYS=(DEEPSEEK_API_KEY DEEPSEEK_API_KEY DASHSCOPE_API_KEY DASHSCOPE_API_KEY DASHSCOPE_API_KEY DASHSCOPE_API_KEY DASHSCOPE_API_KEY DASHSCOPE_API_KEY DASHSCOPE_API_KEY MOONSHOT_API_KEY MOONSHOT_API_KEY ZHIPU_API_KEY ZHIPU_API_KEY ZHIPU_API_KEY ZHIPU_API_KEY ZHIPU_API_KEY ZHIPU_API_KEY ZHIPU_API_KEY ZHIPU_API_KEY
NOTES=(最新 最新 旗舰 均衡 快速 编程 识图 最新 新 最新/编程 识图/稳定 免费/最新 免费 强悍 免费/识图 长文本 最新/旗舰 识图 强悍 最新旗舰 旗舰 高速 新 高速 旧 高速 旧/免费)

# ── Python 环境发现 ──
PY=""
# 测试候选 Python 是否可用（3 秒超时）
_py_test() {
  local cand="$1"
  [[ ! -x "$cand" ]] && return 1
  local _out _tmp
  _tmp=$(mktemp 2>/dev/null) || return 1
  "$cand" -c "import sys; print(sys.version_info[0])" >"$_tmp" 2>/dev/null &
  local _pid=$!
  sleep 3
  if kill -0 $_pid 2>/dev/null; then
    kill $_pid 2>/dev/null; wait $_pid 2>/dev/null
    rm -f "$_tmp"
    return 1  # 3 秒没返回 → 卡死了
  fi
  wait $_pid 2>/dev/null
  read -r _out <"$_tmp"
  rm -f "$_tmp"
  [[ "$_out" = "3" ]] && return 0 || return 1
}
# 顺序: 系统 Python → Homebrew → Anaconda/Miniconda → PATH
for _py in \
  "/usr/bin/python3" \
  "/opt/homebrew/bin/python3" \
  "/usr/local/bin/python3" \
  "$HOME/Documents/Anaconda/anaconda3/bin/python3" \
  "$HOME/anaconda3/bin/python3" \
  "$HOME/miniconda3/bin/python3" \
  "$HOME/miniforge3/bin/python3"; do
  if _py_test "$_py"; then
    PY="$_py"
    break
  fi
done
# 以上都没找到，走 PATH
if [[ -z "$PY" ]]; then
  for cmd in python3 python; do
    p=$(command -v "$cmd" 2>/dev/null) || continue
    if _py_test "$p"; then
      PY="$p"
      break
    fi
  done
fi
unset -f _py_test
if [[ -z "$PY" ]]; then
  echo "  ${RED}需要 Python 3，装一下再试${NC}"
  echo "  安装方法: brew install python3"
  exit 1
fi

# pip 不需要 — relay 二进制已嵌入脚本，直接从脚本尾部提取

# ── 跨 shell 环境变量持久化 ──
# 同时写入 zshenv / bash_profile / profile，三种 shell 都能读到
persist_env() {
  local k="$1" v="$2"
  for profile in "$HOME/.zshenv" "$HOME/.bash_profile" "$HOME/.profile"; do
    "$PY" -c "
import os, re
k = '$k'; v = '$v'; fn = '$profile'
lines = open(fn).readlines() if os.path.exists(fn) else []
new_lines = [l for l in lines if not re.match(r'export\\s+'+k+'=', l)]
new_lines.append(f'export {k}={v}\n')
open(fn, 'w').writelines(new_lines)
" 2>/dev/null || true
  done
}

# ── Python 输入辅助（绕过 zsh 终端输入问题） ──
# 核心思路：input() 的 prompt 写到了 stdout，被 $(...) 捕获了，
#          用户看不见，变量也脏了。
# 修正：prompt 写 stderr（直通终端），user input 写 stdout（被捕获）。
pyread() {
  PYREAD_PROMPT="$1" "$PY" -c '
import os, sys
sys.stderr.write(os.environ["PYREAD_PROMPT"])
sys.stderr.flush()
line = sys.stdin.readline()
if line.endswith("\n"):
    line = line[:-1]
sys.stdout.write(line)
sys.stdout.flush()
'
}
pyread_silent() {
  PYREAD_PROMPT="$1" "$PY" -c '
import getpass, os, sys
sys.stderr.write(os.environ["PYREAD_PROMPT"])
sys.stderr.flush()
sys.stdout.write(getpass.getpass(""))
sys.stdout.flush()
'
}

# ── 工具函数 ──

close_codex() {
  # 关闭 Codex Desktop（避免配置冲突）
  # 只用 pkill，不用 osascript（osascript 会弹权限弹窗吓到用户）
  pkill -f "Codex.app/Contents/MacOS/Codex" 2>/dev/null && sleep 2
  return 0
}

wait_key() {
  pyread "${1:-按任意键继续...}" > /dev/null
}

# 不再需要输入排空，wait_key 使用 read -r 已经干净

# ── Utilities ──

find_index() {
  local code="$1"
  for i in "${(@)CODES}"; do
    if [[ "${CODES[$i]}" == "$code" ]]; then
      echo $i
      return 0
    fi
  done
  return 1
}

find_by_name() {
  local name="$1"
  for i in "${(@)NAMES}"; do
    if [[ "${NAMES[$i]}" == "$name" ]]; then
      echo $i
      return 0
    fi
  done
  return 1
}

find_avail_port() {
  for port in {4446..65535}; do
    if ! lsof -ti :$port >/dev/null 2>&1; then
      echo $port
      return 0
    fi
  done
  echo 4446
}

# ── :check_codex ──

check_codex() {
  local has_app=false has_cli=false has_dir=false
  [[ -d /Applications/Codex.app ]] && has_app=true
  command -v codex >/dev/null 2>&1 && has_cli=true
  [[ -d "$CODEX_DIR" ]] && has_dir=true

  # 全部就绪
  if $has_dir && ($has_app || $has_cli); then
    echo "  ${GREEN}✔ Codex 已就绪${NC}"
    return 0
  fi

  # App 在但没启动过（无 ~/.codex/）-- 循环等待
  if $has_app || $has_cli; then
    while true; do
      echo "  了解到您已经安装了 Codex，先去启动一次吧"
      echo "    打开后按任意键继续..."
      wait_key
      if [[ -d "$CODEX_DIR" ]]; then
        echo "  ${GREEN}✔ Codex 已就绪${NC}"
        return 0
      fi
      echo ""
      echo "  -- 还没有检测到配置目录，请先启动一次 Codex"
    done
  fi

  # 目录在但 App 被删了
  if $has_dir && ! $has_app && ! $has_cli; then
    echo "  ${YELLOW}检测到 ~/.codex/ 配置目录，但 Codex App 已不存在${NC}"
    echo "  请重新安装 Codex"
  fi

  # 检查同目录下是否有 Codex 安装包
  local script_dir="$(cd "$(dirname "$SCRIPT_FILE")" && pwd)"
  local dmg=$(ls "$script_dir"/Codex*.dmg 2>/dev/null | head -1)
  local pkg=$(ls "$script_dir"/Codex*.pkg 2>/dev/null | head -1)
  if [[ -n "$dmg" ]]; then
    echo "  发现安装包: $(basename "$dmg")"
    local yn=$(pyread "  自动安装 Codex Desktop？(Y/n): ")
    if [[ "$yn" != "n" && "$yn" != "N" ]]; then
      echo "  正在安装..."
      local vol=$(hdiutil attach "$dmg" 2>/dev/null | grep -i '/Volumes/Codex' | tail -1 | awk '{$1=$2=""; print $0}' | sed 's/^ *//')
      if [[ -n "$vol" ]]; then
        cp -R "$vol/Codex.app" /Applications/ 2>/dev/null
        hdiutil detach "$vol" 2>/dev/null
        echo "  ${GREEN}✔ Codex Desktop 已安装到 /Applications${NC}"
        mkdir -p "$CODEX_DIR"
        echo "  ${GREEN}✔ Codex 已就绪${NC}"
        return 0
      else
        echo "  ${YELLOW}安装失败，手动安装试试${NC}"
      fi
    fi
  elif [[ -n "$pkg" ]]; then
    echo "  发现安装包: $(basename "$pkg")"
    local yn=$(pyread "  自动安装 Codex？(Y/n): ")
    if [[ "$yn" != "n" && "$yn" != "N" ]]; then
      echo "  正在安装（可能需要输入密码）..."
      sudo installer -pkg "$pkg" -target / 2>/dev/null && \
        echo "  ${GREEN}✔ Codex 安装完成${NC}" || \
        echo "  ${YELLOW}安装失败，手动安装试试${NC}"
    fi
  fi
  echo ""
  echo "  看起来 Codex 还没有安装"
  echo "  可以这样安装:"
  echo "    CLI 版:  npm install -g @openai/codex"
  echo "    桌面版:  https://openai.com/codex 下载安装"
  echo ""
  wait_key "装好了就按任意键继续..."
  return 1
}

# ── :pick ──

pick() {
  echo ""
  local i=0
  for prov_name in DeepSeek Qwen Kimi GLM; do
    echo "  $prov_name:"
    local idxs=()
    for i in {1..$#CODES}; do
      if [[ "${PROVIDERS[$i]}" == "$prov_name" ]]; then
        idxs+=($i)
      fi
    done
    local j=0
    while (( j < $#idxs )); do
      local a=$idxs[$((j+1))]
      if (( j + 1 < $#idxs )); then
        local b=$idxs[$((j+2))]
        printf "    [%s] %-19s %-10s  [%s] %-19s %s\n" "${CODES[$a]}" "${NAMES[$a]}" "${NOTES[$a]}" "${CODES[$b]}" "${NAMES[$b]}" "${NOTES[$b]}"
        (( j += 2 ))
      else
        echo "    [${CODES[$a]}] ${NAMES[$a]}  (${NOTES[$a]})"
        (( j += 1 ))
      fi
    done
  done

  local input=$(pyread "  输入代码(如 D1) 或模型全名: ")
  [[ -z "$input" ]] && input="D1"

  local found=""
  for i in {1..$#CODES}; do
    if [[ "${CODES[$i]}" == "$input" || "${NAMES[$i]}" == "$input" ]]; then
      found=$i
      break
    fi
  done

  if [[ -z "$found" ]]; then
    echo "  没找到这个模型，再试试"
    wait_key
    pick
    return
  fi

  M="${NAMES[$found]}"
  P="${PROVIDERS[$found]}"
  U="${URLS[$found]}"
  K="${KEYS[$found]}"
  echo "  已选: $P / $M"

  # 简短模型介绍
  case "$M" in
    deepseek-v4-pro)   echo "  → 最新旗舰，复杂任务能力强" ;;
    deepseek-v4-flash) echo "  → 轻量快速，日常聊天首选" ;;
    qwen-max)          echo "  → 通义旗舰，综合性能均衡" ;;
    qwen3.6-plus)      echo "  → 最新 Plus 版，代码和推理增强" ;;
    qwen-vl-max)       echo "  → 支持图片识别和理解" ;;
    qwen-coder-plus)   echo "  → 编程专用，代码生成优化" ;;
    kimi-k2.6)         echo "  → Kimi 最新旗舰，编程能力强" ;;
    glm-4.7-flash)     echo "  → 免费可用，日常够用不花钱" ;;
    glm-4v-flash)      echo "  → 免费 + 识图，性价比之选" ;;
    glm-5.1)           echo "  → 智谱最新旗舰，对齐国际一流" ;;
    glm-5v-turbo)      echo "  → 视觉编程，设计稿转代码" ;;
  esac

  RE=high
  SRS=true
  CW=262144
  MCW=1048576
}

# ── :key ──

key() {
  local ak=""
  if [[ -f "$AUTH" ]]; then
    ak=$("$PY" -c "
import json, sys
try:
    d = json.load(open('$AUTH'))
    v = d.get('$K', '')
    if v: print(v[:12])
except: pass
" 2>/dev/null)
  fi

  if [[ -n "$ak" ]]; then
    echo "  上次的 $P Key: ${ak}..."
    local reuse=$(pyread "  还用这个吗？(Y/n): ")
    if [[ "$reuse" != "n" && "$reuse" != "N" ]]; then
      KEY_DISP="${ak:0:8}..."
      # Export from auth.json so Codex CLI sees the real key
      local old_key=$("$PY" -c "import json; print(json.load(open('$AUTH')).get('$K', ''))" 2>/dev/null)
      if [[ -n "$old_key" ]]; then
        export "${K}=${old_key}"
        persist_env "$K" "$old_key"
      fi
      return 0
    fi
  fi

  echo ""
  case "$P" in
    DeepSeek) echo "  去 https://platform.deepseek.com/api_keys 获取 API Key" ;;
    Qwen)     echo "  去 https://bailian.console.aliyun.com/ 获取 API Key" ;;
    Kimi)     echo "  去 https://platform.moonshot.cn/console/api-keys 获取 API Key" ;;
    GLM)      echo "  去 https://bigmodel.cn/apikey/platform 获取 API Key（充值: https://bigmodel.cn/finance-center/finance/pay）" ;;
  esac

  echo "  API URL: $U"

  local key=$(pyread_silent "  粘贴你的 $P API Key: ")
  echo ""

  if [[ -z "$key" ]]; then
    echo "  ${RED}Key 不能为空，再试一次${NC}"
    wait_key
    key
    return
  fi

  # Store key via Python (handles JSON merge safely)
  "$PY" -c "
import json, os
k = '$K'
v = '$key'
af = '$AUTH'
os.makedirs(os.path.dirname(af), exist_ok=True)
if os.path.exists(af):
    d = json.load(open(af))
else:
    d = {}
d[k] = v
json.dump(d, open(af, 'w'), ensure_ascii=False)
" 2>/dev/null

  # Set for current session
  export "${K}=${key}"
  KEY_DISP="${key:0:8}..."
  persist_env "$K" "$key"
  echo "  ${GREEN}✔ Key 已保存${NC}"
}

# ── :extract_bundled_relay ──
# 从脚本末尾的 #B64 区域解码 relay 二进制
extract_bundled_relay() {
  local _target="$HOME/.local/bin/codex-relay"
  mkdir -p "$HOME/.local/bin"
  awk '/^#B64END/{flag=0; next} /^#B64/{flag=1; next} flag' "$SCRIPT_FILE" 2>/dev/null | base64 -d | gzip -d > "$_target"
  chmod +x "$_target"
  # 确保提取出来的不是空文件（最少 1MB 才合理）
  if [[ -x "$_target" ]] && [[ $(stat -f%z "$_target" 2>/dev/null) -gt 1048576 ]]; then
    echo "$_target"
  else
    rm -f "$_target" 2>/dev/null
  fi
}

# ── :extract_think_filter ──
extract_think_filter() {
  local _target="$HOME/.local/bin/codex-think-filter.py"
  mkdir -p "$HOME/.local/bin"
  awk '/^#FILTER_B64END/{flag=0;next} /^#FILTER_B64/{flag=1;next} flag' "$SCRIPT_FILE" 2>/dev/null | base64 -d | gzip -d > "$_target"
  chmod +x "$_target"
  [[ -s "$_target" ]] && echo "$_target" || { rm -f "$_target" 2>/dev/null; }
}

# ── :relay ──

relay() {
  # Kill old relay & filter
  pkill -f codex-relay 2>/dev/null || true
  pkill -f codex-think-filter 2>/dev/null || true
  sleep 2

  # Find available port
  PORT=$(find_avail_port)
  echo "  relay port: $PORT"

  # 从脚本自身提取嵌入式 relay 二进制
  local rp=$(extract_bundled_relay)

  if [[ -z "$rp" ]]; then
    echo "  ${YELLOW}relay 二进制提取失败，脚本可能损坏${NC}"
    wait_key; return 1
  fi
  RELAY_OK=0

  # Show what we're about to start
  echo "  upstream: $U"
  echo "  port:     $PORT"

  # Start relay
  RELAY_KEY=$("$PY" -c "
import json
d = json.load(open('$AUTH'))
print(d.get('$K', ''))
" 2>/dev/null)

  if [[ -z "$RELAY_KEY" ]]; then
    echo "  Key 还没填，补一下就能用了"
    wait_key
    return 1
  fi

  nohup "$rp" --port "$PORT" --upstream "$U" --api-key "$RELAY_KEY" > /dev/null 2>&1 &
  sleep 3

  # Verify
  if lsof -ti :$PORT >/dev/null 2>&1; then
    echo "  ${GREEN}✔ relay 已启动${NC}"
    RELAY_OK=1
      local _ft=$(extract_think_filter)
      if [[ -n "$_ft" ]]; then
        local _fp=$((PORT+1))
        while lsof -ti :$_fp >/dev/null 2>&1; do _fp=$((_fp+1)); done
        echo "  filter port: $_fp (→ relay:$PORT)"
        nohup "$PY" "$_ft" --port "$_fp" --backend "http://127.0.0.1:$PORT" > /tmp/codex-think-filter.log 2>&1 &
        sleep 2
        if lsof -ti :$_fp >/dev/null 2>&1; then
          echo "  ${GREEN}✔ think-filter started${NC}"
          PORT=$_fp
        else
          echo "  ${YELLOW}filter failed, using relay directly${NC}"
        fi
      fi
    fi
  else
    echo "  ${YELLOW}第一次没成功，再试一次...${NC}"
    pkill -f codex-relay 2>/dev/null || true
    sleep 2
    nohup "$rp" --port "$PORT" --upstream "$U" --api-key "$RELAY_KEY" > /dev/null 2>&1 &
    sleep 4
    if lsof -ti :$PORT >/dev/null 2>&1; then
      echo "  ${GREEN}✔ relay 已启动${NC}"
      RELAY_OK=1
        local _ft2=$(extract_think_filter)
        if [[ -n "$_ft2" ]]; then
          local _fp2=$((PORT+1))
          while lsof -ti :$_fp2 >/dev/null 2>&1; do _fp2=$((_fp2+1)); done
          echo "  filter port: $_fp2 (→ relay:$PORT)"
          nohup "$PY" "$_ft2" --port "$_fp2" --backend "http://127.0.0.1:$PORT" > /tmp/codex-think-filter.log 2>&1 &
          sleep 2
          if lsof -ti :$_fp2 >/dev/null 2>&1; then
            echo "  ${GREEN}✔ think-filter started${NC}"
            PORT=$_fp2
          else
            echo "  ${YELLOW}filter failed${NC}"
          fi
        fi
      fi
    else
      echo "  ${YELLOW}relay 在端口 $PORT 没起来，用 [3] 看看状态？${NC}"
    fi
  fi
}

# Same as :relay but skips pip install (assumes already installed)
relay_restart() {
  pkill -f codex-relay 2>/dev/null || true
  pkill -f codex-think-filter 2>/dev/null || true
  sleep 2

  PORT=$(find_avail_port)
  echo "  relay port: $PORT"
  echo "  relay upstream: $U"

  RELAY_OK=0

  local rp=$("$PY" -c "
import os, sys, shutil
p = shutil.which('codex-relay')
if p and os.access(p, os.X_OK): print(p); sys.exit(0)
home = os.path.expanduser('~')
for c in (os.path.join(home, '.local', 'bin', 'codex-relay'),
          os.path.join(os.path.dirname(sys.executable), 'codex-relay'),
          os.path.join(os.path.dirname(sys.executable), 'bin', 'codex-relay')):
    if os.access(c, os.X_OK): print(c); sys.exit(0)
" 2>/dev/null)
  if [[ -z "$rp" ]]; then
    # 从脚本提取嵌入版
    rp=$(extract_bundled_relay 2>/dev/null)
  fi
  if [[ -z "$rp" ]]; then
    echo "  relay 还没装，用 [1] 跑一遍就齐了"
    wait_key
    return 1
  fi

  RELAY_KEY=$("$PY" -c "
import json
d = json.load(open('$AUTH'))
print(d.get('$K', ''))
" 2>/dev/null)

  nohup "$rp" --port "$PORT" --upstream "$U" --api-key "$RELAY_KEY" > /dev/null 2>&1 &
  sleep 3

  if lsof -ti :$PORT >/dev/null 2>&1; then
    echo "  relay OK"
    RELAY_OK=1
      local _ft3=$(extract_think_filter)
      if [[ -n "$_ft3" ]]; then
        local _fp3=$((PORT+1))
        while lsof -ti :$_fp3 >/dev/null 2>&1; do _fp3=$((_fp3+1)); done
        nohup "$PY" "$_ft3" --port "$_fp3" --backend "http://127.0.0.1:$PORT" > /tmp/codex-think-filter.log 2>&1 &
        sleep 2
        if lsof -ti :$_fp3 >/dev/null 2>&1; then
          echo "  ${GREEN}✔ think-filter started${NC}"
          PORT=$_fp3
        else
          echo "  ${YELLOW}filter failed${NC}"
        fi
      fi
    fi
  else
    echo "  Relay 未响应，重试..."
    pkill -f codex-relay 2>/dev/null || true
    sleep 2
    nohup "$rp" --port "$PORT" --upstream "$U" --api-key "$RELAY_KEY" > /dev/null 2>&1 &
    sleep 4
    if lsof -ti :$PORT >/dev/null 2>&1; then
      echo "  relay OK"
      RELAY_OK=1
        local _ft4=$(extract_think_filter)
        if [[ -n "$_ft4" ]]; then
          local _fp4=$((PORT+1))
          while lsof -ti :$_fp4 >/dev/null 2>&1; do _fp4=$((_fp4+1)); done
          nohup "$PY" "$_ft4" --port "$_fp4" --backend "http://127.0.0.1:$PORT" > /tmp/codex-think-filter.log 2>&1 &
          sleep 2
          if lsof -ti :$_fp4 >/dev/null 2>&1; then
            echo "  ${GREEN}✔ think-filter started${NC}"
            PORT=$_fp4
          else
            echo "  ${YELLOW}filter failed${NC}"
          fi
        fi
      fi
    else
      echo "  WARN: relay 未能在端口 $PORT 启动"
    fi
  fi
}

# ── :config ──

config() {
  PORT=${PORT:-4446}
  echo "  config port: $PORT"

  mkdir -p "$CODEX_DIR"


  # 确保 K 有值（可能来自高级设置入口，没经过 pick）
  if [[ -z "$K" && -f "$VARS" ]]; then
    K=$(grep '^K=' "$VARS" 2>/dev/null | head -1 | sed 's/^K=//')
  fi
  K=${K:-DEEPSEEK_API_KEY}

  # Read API key from auth.json for inline config
  local inline_key=$("$PY" -c "
import json
try:
    d = json.load(open('$AUTH'))
    print(d.get('$K', ''))
except: pass
" 2>/dev/null)

  cat > "$CONFIG" << EOF
model_provider = "custom"

model = "$M"

model_reasoning_effort = "$RE"

[model_providers.custom]
name = "$M"
base_url = "http://127.0.0.1:$PORT/v1"
wire_api = "responses"
requires_openai_auth = false
api_key = "${inline_key}"

[model_properties."$M"]
context_window = $CW
max_context_window = $MCW
supports_parallel_tool_calls = true
supports_reasoning_summaries = $SRS
input_modalities = ["text"]
EOF

  if [[ -f "$CONFIG" ]]; then
    echo "  ${GREEN}✔ 配置已写入${NC}"
  else
    echo "  ${RED}配置写不进去，检查一下权限再试${NC}"
    wait_key
    return 1
  fi

  # Write vars file（包含 PY 供 restart-relay.sh 使用）
  cat > "$VARS" << EOF
PY="$PY"
M=$M
P=$P
U=$U
RE=$RE
SRS=$SRS
CW=$CW
MCW=$MCW
K=$K
PORT=$PORT
EOF

  # Migrate sessions
  migrate

  MP="custom"
}

# ── :migrate ──

migrate() {
  local model="${1:-$M}"
  "$PY" -c "
import glob, os, sqlite3, sys
model = sys.argv[1]
cd = os.path.expanduser('~/.codex')
for f in glob.glob(cd + '/*.sqlite'):
    try:
        conn = sqlite3.connect(f)
        tbl = conn.execute(\"SELECT name FROM sqlite_master WHERE type='table' AND name='threads'\").fetchone()
        if not tbl:
            conn.close()
            continue
        print(os.path.normpath(f))
        before = conn.execute('SELECT id, model_provider, model FROM threads').fetchall()
        if before:
            print('  before:', len(before), 'threads')
        cur = conn.execute(\"UPDATE threads SET model_provider='custom', model=?\", (model,))
        print('  migrated', cur.rowcount, 'sessions')
        conn.commit()
        after = conn.execute('SELECT model_provider, model FROM threads').fetchall()
        print('  after:', list(set(r[1] for r in after)))
        conn.close()
    except Exception as e:
        print('  migrate skip:', os.path.basename(f), e)
" "$model"
}

# ── :tasks ──

tasks() {
  # 保存变量供 restart-relay.sh 使用
  cat > "$VARS" << EOF
PY="$PY"
U="$U"
K="$K"
EOF

  # Write restart-relay.sh
  cat > "$RS" << 'RSEOF'
#!/bin/zsh
CODEX_DIR="$HOME/.codex"
AUTH="$CODEX_DIR/auth.json"
VARS="$CODEX_DIR/_vars.sh"

# Check if relay already alive on port 4446
# Use full path — crontab runs with PATH=/usr/bin:/bin, missing /usr/sbin
if /usr/sbin/lsof -ti :4446 >/dev/null 2>&1; then
  exit 0
fi

source "$VARS" 2>/dev/null || exit 1
RELAY_KEY=$("$PY" -c "import json; d=json.load(open('$AUTH')); print(d.get('$K',''))" 2>/dev/null)
[[ -z "$RELAY_KEY" ]] && exit 1

pkill -f codex-relay 2>/dev/null || true
sleep 2

RSPORT=4446
rp=$("$PY" -c "
import os, sys, shutil
p = shutil.which('codex-relay')
if p and os.access(p, os.X_OK): print(p); sys.exit(0)
home = os.path.expanduser('~')
for c in (os.path.join(home, '.local', 'bin', 'codex-relay'),
          os.path.join(os.path.dirname(sys.executable), 'codex-relay')):
    if os.access(c, os.X_OK): print(c); sys.exit(0)
" 2>/dev/null)
[[ -z "$rp" ]] && exit 1

nohup "$rp" --port "$RSPORT" --upstream "$U" --api-key "$RELAY_KEY" > /dev/null 2>&1 &
exit 0
RSEOF
  chmod +x "$RS"

  # ── LaunchAgent 自动保活（macOS 原生，无 TCC 权限问题）──
  mkdir -p "$HOME/Library/LaunchAgents"
  local plist="$HOME/Library/LaunchAgents/com.codex.relay.plist"
  cat > "$plist" << PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.codex.relay</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>$RS</string>
    </array>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>AbandonProcessGroup</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/codex-relay-keepalive.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/codex-relay-keepalive.log</string>
</dict>
</plist>
PLISTEOF

  # 卸载旧版再加载（确保配置更新）
  launchctl bootout gui/$(id -u)/com.codex.relay 2>/dev/null || true
  if launchctl bootstrap gui/$(id -u) "$plist" 2>/dev/null; then
    echo "  ${GREEN}✔ 自动保活已开启（LaunchAgent，每 60 秒检查）${NC}"
  else
    echo "  ${YELLOW}⚠ LaunchAgent 加载失败，降级到 crontab${NC}"
    local cronjob="*/5 * * * * $RS"
    if crontab -l 2>/dev/null | grep -q "$RS"; then
      crontab -l 2>/dev/null | grep -v "$RS" | crontab -
    fi
    (crontab -l 2>/dev/null; echo "$cronjob") | crontab - 2>/dev/null && \
      echo "  ${GREEN}✔ 自动保活已开启（crontab，每 5 分钟）${NC}" || \
      echo "  ${YELLOW}⚠ 自动保活没开成功${NC}"
  fi

  echo "  ${GREEN}✔ 任务已就绪${NC}"
}

# ── :uninstall ──

uninstall() {
  echo ""
  echo "  ╔══════════════════════════════════════════════╗"
  echo "  ║   恢复出厂设置会做以下操作:                    ║"
  echo "  ║                                              ║"
  echo "  ║   ✓ 终止 relay 进程                          ║"
  echo "  ║   ✓ 移除 LaunchAgent 自动保活                  ║"
  echo "  ║   ✓ 清除 shell profile 中的 API Key 环境变量   ║"
  echo "  ║   ✓ 重置 config.toml 为 Codex 默认配置        ║"
  echo "  ║   ✓ 清空 auth.json (API Key)                  ║"
  echo "  ║   ✓ 卸载 codex-relay                          ║"
  echo "  ║                                              ║"
  echo "  ║   ✗ 不会删除你的历史会话数据                   ║"
  echo "  ║   ✗ 不会卸载 Codex 本身                       ║"
  echo "  ║                                              ║"
  echo "  ║  输入 yes 确认，输其他任意内容取消              ║"
  echo "  ╚══════════════════════════════════════════════╝"
  echo ""
  local confirm=$(pyread "  确认恢复出厂设置？(yes): ")
  if [[ "$confirm" != "yes" ]]; then
    echo "  好的，不动你配置～"
    wait_key
    return
  fi
  echo ""

  echo "  正在清理..."
  pkill -f codex-relay 2>/dev/null || true
  echo "    ✔ relay 进程已终止"

  # 移除 LaunchAgent
  launchctl bootout gui/$(id -u)/com.codex.relay 2>/dev/null || true
  rm -f "$HOME/Library/LaunchAgents/com.codex.relay.plist" 2>/dev/null || true
  echo "    ✔ LaunchAgent 自动保活已移除"

  # 移除 crontab（老版本残留清理）
  crontab -l 2>/dev/null | grep -v "$RS" | crontab - 2>/dev/null || true

  for profile in "$HOME/.zshenv" "$HOME/.bash_profile" "$HOME/.profile" "$HOME/.zshrc"; do
    if [[ -f "$profile" ]]; then
      for ek in DEEPSEEK_API_KEY DASHSCOPE_API_KEY MOONSHOT_API_KEY ZHIPU_API_KEY; do
        sed -i '' "/^export $ek=/d" "$profile" 2>/dev/null || true
      done
    fi
  done
  echo "    ✔ API Key 环境变量已清除"

  mkdir -p "$CODEX_DIR"
  cat > "$CONFIG" << 'EOF'
# Codex default configuration
model = "gpt-5.5-codex"
model_provider = "openai"
model_reasoning_effort = "medium"
model_verbosity = "medium"
approval_policy = "on-request"
sandbox_mode = "workspace-write"
web_search = "cached"
EOF
  echo "    ✔ 配置已恢复默认"

  echo "{}" > "$AUTH"
  echo "    ✔ API Key 已清空"

  rm -f "$CODEX_DIR/restart-relay.sh"
  rm -f "$CODEX_DIR/config.toml.bak" "$CODEX_DIR/backup_auth.json"
  rm -f "$VARS"
  echo "    ✔ 辅助文件已清理"

  rm -f "$CODEX_DIR"/logs_*.sqlite "$CODEX_DIR"/goals_*.sqlite 2>/dev/null
  rm -rf "$CODEX_DIR"/logs "$CODEX_DIR"/cache "$CODEX_DIR"/.tmp "$CODEX_DIR"/.sandbox "$CODEX_DIR"/.sandbox-bin "$CODEX_DIR"/.sandbox-secrets
  echo "    ✔ 缓存已清理"

  if "$PY" --version >/dev/null 2>&1; then
    "$PY" -m pip uninstall codex-relay -y >/dev/null 2>&1 && echo "    ✔ relay 已卸载" || echo "    relay 之前没安装，跳过"
  fi

  echo ""
  echo "  全清了～ Codex 回到出厂状态，直接用 OpenAI 或别的服务就好"
  cat_mood
  sleep 2
}

# ── :status ──

status() {
  echo ""
  echo "  ─── 当前状态 ───"
  if lsof -ti :4446 >/dev/null 2>&1; then
    echo "  中转服务: ✔ 运行中（端口 4446）"
  else
    echo "  中转服务: 未启动"
  fi
  if [[ -f "$CONFIG" ]]; then
    local model=$(grep '^model = ' "$CONFIG" 2>/dev/null | head -1 | sed 's/.*"\(.*\)".*/\1/')
    echo "  当前模型: ${model:-还没设置}"
  else
    echo "  配置: 还没初始化"
  fi
  echo ""
  wait_key "按任意键返回菜单..."
  cat_mood
}

# ── 模型参数 ──

params() {
  [[ -f "$VARS" ]] && source "$VARS"
  M=${M:-$(grep '^model = ' "$CONFIG" 2>/dev/null | head -1 | sed 's/.*"\(.*\)".*/\1/')}
  RE=${RE:-$(grep 'model_reasoning_effort = ' "$CONFIG" 2>/dev/null | head -1 | sed 's/.*"\(.*\)".*/\1/')}
  SRS=${SRS:-$(grep 'supports_reasoning_summaries = ' "$CONFIG" 2>/dev/null | head -1 | sed 's/.* = //')}
  CW=${CW:-$(grep 'context_window = ' "$CONFIG" 2>/dev/null | head -1 | sed 's/.* = //')}
  MCW=${MCW:-$(grep 'max_context_window = ' "$CONFIG" 2>/dev/null | head -1 | sed 's/.* = //')}

  # Clean quotes
  RE=$(echo "$RE" | tr -d ' "')
  SRS=$(echo "$SRS" | tr -d ' "')
  CW=$(echo "$CW" | tr -d ' "')
  MCW=$(echo "$MCW" | tr -d ' "')

  echo ""
  echo "  1. 推理强度 (reasoning_effort)  = $RE"
  echo "     选项: high medium low none"
  echo "     high  = 质量最高，适合数学/代码/分析，但耗时更长、消耗更多 token"
  echo "     medium= 平衡模式，兼顾质量与速度"
  echo "     low   = 快速响应，适合简单对话，节省 token"
  echo "     none  = 不额外推理，速度最快，适合明确指令类任务"
  echo ""
  echo "  2. 推理摘要 (reasoning_summaries) = $SRS"
  echo "     选项: true false"
  echo "     true = 显示思考过程摘要（适合 R1 等推理模型），便于理解模型思路"
  echo "     false= 不显示推理过程，节省 token"
  echo ""
  echo "  3. 上下文窗口 (context_window) = $CW"
  echo "     模型单次能记住的最大 token 数，越大越能处理长对话但消耗更多"
  echo ""
  echo "  4. 最大上下文 (max_context_window) = $MCW"
  echo "     上下文窗口的硬上限，超过此长度的输入会被截断"
  echo ""
  echo "  [0] 返回主菜单"
  echo ""
  local opt=$(pyread "  选择: ")

  case "$opt" in
    0) return ;;
    1)
      RE=$(pyread "  推理强度 (high/medium/low/none): ")
      [[ -z "$RE" ]] && RE=high
      ;;
    2)
      SRS=$(pyread "  推理摘要 (true/false): ")
      [[ -z "$SRS" ]] && SRS=true
      ;;
    3)
      CW=$(pyread "  上下文窗口: ")
      [[ -z "$CW" ]] && CW=262144
      ;;
    4)
      MCW=$(pyread "  最大上下文: ")
      [[ -z "$MCW" ]] && MCW=1048576
      ;;
    *)
      echo "  选 0 到 4 之间的数字就好"
      wait_key
      params
      return
      ;;
  esac
  echo ""
  config
  echo "  ${GREEN}✔ 参数已更新${NC}"
  cat_mood
  wait_key
}

# ── 菜单 ──

menu() {
  while true; do
    echo ""
    echo "  ══════════════════════════════════════════════════════"
    echo "    Codex 助手  —  有什么想做的？"
    echo "  ══════════════════════════════════════════════════════"
    echo ""
    echo "  ── 快速操作 ──"
    echo "  ${GREEN}[1]${NC} 快速开始  —— 选模型 + 输 Key + 自动配置，一次搞定"
echo "  支持 DeepSeek / Qwen / Kimi / GLM"
    echo "  ${CYAN}[2]${NC} 换个模型  —— 会话还在，换个大模型继续聊"
    echo ""
    echo "  ── 信息与维护 ──"
    echo "  ${CYAN}[3]${NC} 看看状态  —— 当前用的什么模型、服务跑没跑"
    echo "  ${YELLOW}[4]${NC} 恢复出厂  —— 清空配置，回到最初的状态"
    echo "  ${CYAN}[5]${NC} 高级设置  —— 推理强度、上下文长度这些参数"
    echo ""
    echo "  ── 其他 ──"
    echo "  ${RED}[0]${NC} 退出"
    echo ""
    local choice=$(pyread "  想做什么？输入数字: ")
    [[ -z "$choice" ]] && continue

    case "$choice" in
      0) echo ""; cat_mood; echo "  好的，下次见～ 随时回来找我聊"; exit 0 ;;
      3) status ;;
      4) close_codex; uninstall ;;
      5)
        if [[ ! -f "$CONFIG" ]]; then
          echo "  还没配过呢，用 [1] 快速开始就好"
          cat_mood
          wait_key
          continue
        fi
        local mp=$(grep '^model_provider = ' "$CONFIG" 2>/dev/null | head -1 | sed 's/.*"\(.*\)".*/\1/')
        if [[ "$mp" != "custom" ]]; then
          echo "  高级参数只有用中转服务接入第三方模型时才能调整"
          echo "  当前 provider: ${mp:-未设置}"
          echo "  用 [1] 快速开始或 [2] 换个模型吧"
          cat_mood
          wait_key
          continue
        fi
        params
        ;;
      1)
        close_codex
        echo ""
        echo "  ${BOLD}[1/3]${NC} 选模型"
        check_codex || continue
        pick
        echo "  ${GREEN}[1/3] ✓${NC}"
        echo ""
        echo "  ${BOLD}[2/3]${NC} 配置 Key  →  ${K}"
        key
        echo "  ${GREEN}[2/3] ✓${NC}"
        echo ""
        echo "  ${BOLD}[3/3]${NC} 启动中转 + 写入配置"
        # 循环等待阶段用户已打开 Codex，杀一次释放锁，避免 config/migrate 时 SQLite 冲突
        close_codex
        relay
        config
        tasks
        echo "  ${GREEN}[3/3] ✓${NC}"
        echo ""
        echo "  ┌─────────────────────────────────────────────┐"
        echo "  │  ${GREEN}✓  搞定了${NC}                            │"
        echo "  │                                             │"
        printf "  │  模型    ${CYAN}%-26s${NC}  │\n" "$P / $M"
        printf "  │  Key     ${CYAN}%-26s${NC}  │\n" "${KEY_DISP:----}"
        if [[ $RELAY_OK -eq 1 ]]; then
          printf "  │  relay   ${CYAN}127.0.0.1:%-15s${NC}  │\n" "$PORT"
          echo "  │  状态    ${GREEN}运行中${NC}                         │"
          echo "  │  现在可以打开 Codex 使用了                            │"
        else
          printf "  │  relay   ${CYAN}127.0.0.1:%-15s${NC}  │\n" "$PORT"
          echo "  │  状态    ${RED}未启动${NC}                         │"
          echo "  │  ${YELLOW}提示: 用 [3] 查看状态或重装一遍${NC}         │"
        fi
        echo "  └─────────────────────────────────────────────┘"
        cat_mood
        wait_key "按任意键返回菜单..."
        ;;
      2)
        close_codex
        if [[ ! -f "$CONFIG" ]]; then
          echo "  还没配过呢，用 [1] 快速开始就好"
          cat_mood
          wait_key
          continue
        fi
        # [2] 先看进程（同 [3]），再看二进制文件
        if ! lsof -ti :${PORT:-4446} >/dev/null 2>&1; then
          echo "  中转服务不在运行"
          echo "  尝试启动..."
          # 进程不在，找二进制：PATH → 脚本嵌入提取
          if ! "$PY" -c "
import os, sys, shutil
p = shutil.which('codex-relay')
if p and os.access(p, os.X_OK): sys.exit(0)
home = os.path.expanduser('~')
lb = os.path.join(home, '.local', 'bin', 'codex-relay')
if os.access(lb, os.X_OK): sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
            local _relay_path
            _relay_path=$(extract_bundled_relay 2>/dev/null)
            if ! "$PY" -c "
import os, sys, shutil
p = shutil.which('codex-relay')
if p and os.access(p, os.X_OK): sys.exit(0)
home = os.path.expanduser('~')
lb = os.path.join(home, '.local', 'bin', 'codex-relay')
if os.access(lb, os.X_OK): sys.exit(0)
sys.exit(1)
" 2>/dev/null; then
              echo "  中转服务还没装，用 [1] 快速开始一次性配齐"
              cat_mood
              wait_key
              continue
            fi
          fi
        fi
        echo ""
        echo "  ─────────────────────────────────────────────────"
        echo "  ${CYAN}  选一个新模型${NC}"
        echo "   不满意随时切回来，旧的配置还在"
        echo "  ─────────────────────────────────────────────────"
        pick
        echo ""
        echo "  ─────────────────────────────────────────────────"
        echo "  ${CYAN}  API Key（上次的自动复用，想换就输新的）${NC}"
        echo "  ─────────────────────────────────────────────────"
        key
        echo ""
        echo "  ─────────────────────────────────────────────────"
        echo "  ${CYAN}  重启中转服务 + 更新配置...${NC}"
        echo "  ─────────────────────────────────────────────────"
        relay_restart
        config
        tasks
        echo ""
        echo "  ═════════════════════════════════════════════════"
        if [[ $RELAY_OK -eq 1 ]]; then
          echo "  ${GREEN}  已经切换到 $P / $M ✅${NC}"
          echo "   会话还在，放心聊"
        else
          echo "  ${YELLOW}  模型已切换，但 relay 没跑起来${NC}"
          echo "   用 [3] 看看状态，或用 [1] 重装一遍"
        fi
        echo "  ═════════════════════════════════════════════════"
        cat_mood
        wait_key "按任意键返回菜单..."
        ;;
      *)
        echo "  选 0 到 5 之间的数字就好"
        wait_key "按任意键继续..."
        ;;
    esac
  done
}

# ── 宠物猫 (10种表情) ──
CAT_EYES=("o.o"  "^.^"  "@.@"  "-.-"  ">.<"  "O.O"  "*.*"  "u.u"  "O.o"  "^.o")
CAT_MOUTHS=("> ^ <" "> w <" "> ^ <" "> z <" "~ ^ ~" "> w <" "> v <" "> . <" "> o <" "> ^ <")
CAT_LABELS=("普通" "开心" "好奇" "想睡" "烦躁" "兴奋" "爱你" "委屈" "震惊" "wink")

# ── 欢迎画面 ──

welcome() {
  local idx=$(( RANDOM % 10 + 1 ))
  local eye="${CAT_EYES[$idx]}"
  local mouth="${CAT_MOUTHS[$idx]}"
  local label="${CAT_LABELS[$idx]}"
  # clear 在无 TTY 时会卡死（如重定向测试），只在实际终端执行
  [[ -t 1 ]] && clear 2>/dev/null || true
  echo ""
  echo "  ┌─────────────────────────────────────────┐"
  sleep 0.15
  echo "  │        /\_/\                            │"
  sleep 0.15
  echo "  │       ( ${eye} )    Codex 助手          │"
  sleep 0.15
  echo "  │        ${mouth}     让大模型为你所用      │"
  sleep 0.15
  echo "  │                选模型→输Key→开聊         │"
  sleep 0.15
  echo "  └─────────────────────────────────────────┘"
  sleep 0.4
  echo ""
  echo "  ${label}  ~  ${eye}"
  sleep 0.2
  sleep 0.2
  echo "  免费、最新、识图模型，随时切换"
  sleep 0.2
  echo ""
}

# ── 随机猫表情 (紧凑版，用于操作结束) ──

cat_mood() {
  local idx=$(( RANDOM % 10 + 1 ))
  local eye="${CAT_EYES[$idx]}"
  local mouth="${CAT_MOUTHS[$idx]}"
  local label="${CAT_LABELS[$idx]}"
  echo ""
  echo "    /\\_/\\ (${eye})  ${mouth}  ${label}"
  echo ""
}

